rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Groups: public read (player list), public write (score submission — players are unauthenticated)
    match /groups/{groupId} {
      allow read: if true;
      allow write: if true;
    }

    // Tournaments metadata: public read, authenticated write
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Michigan tournament: public read, public write (same as groups — players are unauthenticated)
    match /michigan/{groupId} {
      allow read: if true;
      allow write: if true;
    }

    // Calcutta: public read, event doc admin-write, team scores public-write
    match /calcuttaEvents/{eventId} {
      allow read: if true;
      allow write: if request.auth != null;

      match /teams/{teamId} {
        allow read: if true;
        // Allow anyone to update scores field; team management (create/delete) requires auth
        allow update: if true;
        allow create, delete: if request.auth != null;
      }
    }
  }
}
