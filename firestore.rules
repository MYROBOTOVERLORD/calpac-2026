rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Groups: public read (player list), public write (score submission — players are unauthenticated)
    match /groups/{groupId} {
      allow read: if true;
      allow write: if true;
    }

    // Tournaments metadata: public read, authenticated write
    match /tournaments/{tournamentId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Calcutta: public read, authenticated write (admin only)
    match /calcuttaEvents/{eventId} {
      allow read: if true;
      allow write: if request.auth != null;

      match /teams/{teamId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }
  }
}
